<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_whiteboard_board_tree" model="ir.ui.view">
        <field name="name">whiteboard.board.tree</field>
        <field name="model">whiteboard.board</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="thumbnail" widget="image" class="oe_avatar"/>
                <field name="write_date"/>
            </tree>
        </field>
    </record>

    <record id="view_whiteboard_board_form" model="ir.ui.view">
        <field name="name">whiteboard.board.form</field>
        <field name="model">whiteboard.board</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_whiteboard" type="object"
                            string="Open Whiteboard" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="user_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="thumbnail" widget="image"/>
                    </group>
                    <group>
                        <field name="data_json" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_whiteboard_board" model="ir.actions.act_window">
        <field name="name">Saved Board Record</field>
        <field name="res_model">whiteboard.board</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('user_id', '=', uid), ('active', '=', True)]</field>
        <field name="context">{'default_user_id': uid}</field>
    </record>
</odoo>

