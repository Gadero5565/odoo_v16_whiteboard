<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoo_whiteboard.WhiteboardAction" owl="1">
        <div class="o_whiteboard_action">
            <div class="o_whiteboard_toolbar" role="toolbar" aria-label="Whiteboard toolbar">
                <div class="o_whiteboard_toolbar_scroll">
                    <div class="o_whiteboard_toolbar_left o_wb_group">
                        <span class="o_whiteboard_title">
                            <i class="fa fa-pencil-square-o me-2"/>
                            Whiteboard
                        </span>

                         <div class="o_wb_field">
                            <i class="fa fa-folder-open o_wb_field_icon"/>
                            <select class="form-control form-control-sm o_whiteboard_select"
                                    t-on-change="onSelectBoard"
                                    t-att-value="state.boardId">
                                <option value="">-- My default board --</option>
                                <t t-foreach="state.boards" t-as="board" t-key="board.id">
                                    <option t-att-value="board.id" t-att-selected="board.id === state.boardId">
                                        <t t-esc="board.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <div class="o_wb_field">
                            <i class="fa fa-tag o_wb_field_icon"/>
                            <input class="form-control form-control-sm o_whiteboard_name"
                                   placeholder="Board name"
                                   t-model="state.boardName"/>
                        </div>

                        <div class="o_wb_field o_wb_color">
                            <span class="o_whiteboard_label">Color</span>
                            <input type="color" t-att-value="state.color" t-on-input="setColor" aria-label="Brush color"/>
                        </div>

                        <div class="o_wb_field o_wb_width">
                            <span class="o_whiteboard_label">Width</span>
                            <input type="range" min="1" max="40" t-att-value="state.width" t-on-input="setWidth" aria-label="Brush width"/>
                        </div>
                    </div>

                    <div class="o_whiteboard_toolbar_right o_wb_group">
                        <button type="button" class="btn btn-secondary btn-sm o_wb_btn" t-on-click="setPen" t-att-title="'Pen'">
                            <i class="fa fa-pencil me-1"/> Pen
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm o_wb_btn" t-on-click="setEraser" t-att-title="'Eraser'">
                            <i class="fa fa-eraser me-1"/> Eraser
                        </button>
                        <button type="button" class="btn btn-secondary btn-sm o_wb_btn" t-on-click="addText" t-att-title="'Add text'">
                            <i class="fa fa-font me-1"/> Text
                        </button>

                        <span class="o_wb_divider"/>

                        <button type="button" class="btn btn-outline-secondary btn-sm o_wb_btn" t-on-click="undo" t-att-title="'Undo'">
                            <i class="fa fa-undo me-1"/> Undo
                        </button>
                        <button type="button" class="btn btn-outline-secondary btn-sm o_wb_btn" t-on-click="redo" t-att-title="'Redo'">
                            <i class="fa fa-repeat me-1"/> Redo
                        </button>

                        <span class="o_wb_divider"/>

                        <button type="button" class="btn btn-outline-danger btn-sm o_wb_btn" t-on-click="clearCanvas" t-att-title="'Clear board'">
                            <i class="fa fa-trash me-1"/> Clear
                        </button>
                        <button type="button" class="btn btn-primary btn-sm o_wb_btn o_wb_btn_primary" t-on-click="save" t-att-title="'Save'">
                            <i class="fa fa-cloud-upload me-1"/> Save
                        </button>
                        <button type="button" class="btn btn-outline-primary btn-sm o_wb_btn" t-on-click="exportPNG" t-att-title="'Export PNG'">
                            <i class="fa fa-download me-1"/> Export
                        </button>
                    </div>
                </div>
            </div>

            <div class="o_whiteboard_body">
                <t t-if="state.loading">
                    <div class="o_whiteboard_loading">
                        <span class="fa fa-spinner fa-spin me-2"/> Loading whiteboard…
                    </div>
                </t>

                <!-- Stage becomes a “paper” area, scrollable if larger than viewport -->
                <div class="o_whiteboard_stage" t-ref="wrap">
                    <canvas t-ref="canvas" class="o_whiteboard_canvas"/>
                </div>
            </div>
        </div>
    </t>
</templates>